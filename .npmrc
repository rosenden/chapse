# GitLab Package Registry for @galactik scope
# Replace ${GALACTIK_TOKEN} with your GitLab Personal Access Token
# or set it in your environment: export GALACTIK_TOKEN=your_token_here
@galactik:registry=https://gitlab.chapsvision.in/api/v4/packages/npm/
//gitlab.chapsvision.in/api/v4/packages/npm/:_authToken=${GALACTIK_TOKEN}
